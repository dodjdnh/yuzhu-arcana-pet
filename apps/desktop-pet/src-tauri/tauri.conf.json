{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AstrBot Desktop Pet",
  "version": "0.1.0",
  "identifier": "com.astrbot.desktop_pet",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "AstrBot Desktop Pet",
        "width": 240,
        "height": 390,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
